# Copy this file to email.env (which is gitignored) and fill in real values.
# EMAIL_PASS must be a Gmail "App Password", not your normal login password:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification on).

EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxx
EMAIL_TO=you@gmail.com,someone_else@gmail.com
